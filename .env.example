# Database
DATABASE_URL=postgresql://wfm:wfm@db:5432/wfmintel

# Authentication
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# LLM Provider (claude | ollama | opencode)
LLM_PROVIDER=claude

# Anthropic/Claude (required if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Ollama (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenCode (required if LLM_PROVIDER=opencode)
OPENCODE_API_KEY=...
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=qwen3.6-plus

# Crawler Settings
DISCOVERY_DEPTH=1
JS_RENDERING_ENABLED=true

# Tavily Web Search API (get key at https://tavily.com)
TAVILY_API_KEY=tvly-...

# Search Settings
SEARCH_RELEVANCE_THRESHOLD=0.5
SEARCH_QUERIES_PER_COMPANY=8

# Frontend Dev Server (optional)
# For local dev outside Docker: VITE_API_TARGET=http://localhost:8000
# For Docker: VITE_API_TARGET=http://backend:8000
